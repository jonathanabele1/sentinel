# Sentinel — local development environment
# Copy to .env and fill in real values.

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# --- Database ---
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- GitHub App ---
# Create a GitHub App: https://github.com/settings/apps/new
# Required permissions: pull_requests:write, contents:read, metadata:read
# Subscribe to events: pull_request, pull_request_review, issue_comment
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=./secrets/github-app.pem
GITHUB_WEBHOOK_SECRET=replace-with-strong-random-string

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=sentinel-api
OTEL_TRACES_SAMPLER=parentbased_always_on
